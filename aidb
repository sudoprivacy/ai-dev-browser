#!/usr/bin/env bash
# ai-dev-browser CLI — zero-dependency bootstrap for macOS/Linux.
#
# Usage:
#   ./aidb <tool> [args]        Run a tool directly
#   ./aidb --list               List available tools (ls tools/)
#   ./aidb <tool> --help        Tool-specific help
#
# On first run, installs uv (if needed) and sets up the environment.
# Requires: curl. Does NOT require Python pre-installed.

set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure uv is available (installs to ~/.local/bin, no sudo)
if ! command -v uv &>/dev/null; then
    echo "Installing uv (Python package manager)..." >&2
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="$HOME/.local/bin:$PATH"
fi

if [[ "${1:-}" == "--list" ]]; then
    ls "$DIR/ai_dev_browser/tools/"*.py | xargs -I{} basename {} .py | grep -v '^_'
    exit 0
fi

if [[ $# -eq 0 || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: aidb <tool> [args]"
    echo ""
    echo "Run 'aidb --list' to see available tools."
    echo "Run 'aidb <tool> --help' for tool-specific help."
    exit 0
fi

tool="${1//-/_}"
shift
exec uv run --directory "$DIR" python -m "ai_dev_browser.tools.$tool" "$@"
